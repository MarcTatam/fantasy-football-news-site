# Backend (place at backend/.env)
# ------------------------------------------------------------

# OpenAI API key — used by langchain-openai for report generation.
OPENAI_API_KEY=sk-...

# Path to a Google Cloud service account key with Firestore access.
# The Firestore client picks this up automatically.
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# (Optional) The Google Cloud project ID, if not inferable from the
# service account credentials.
# GOOGLE_CLOUD_PROJECT=my-gcp-project

# Your FPL mini-league ID. Currently hardcoded in
# football_reports/datasources/fpl.py — see README "Known issues".
FPL_LEAGUE_ID=161855

# Comma-separated list of allowed CORS origins (frontend URLs).
# Local dev: http://localhost:3000
# Production: your deployed frontend URL, e.g. https://fantasy-frontend-abc123.run.app
ALLOWED_ORIGINS=http://localhost:3000


# Frontend (place at frontend/.env.local)
# ------------------------------------------------------------

# URL of the running backend. For local dev, point at uvicorn.
# In production, this is your Cloud Run backend URL.
#
# NOTE: this is a NEXT_PUBLIC_ var, so it's baked in at *build* time —
# the frontend Dockerfile takes it as a build arg.
NEXT_PUBLIC_REPORT_GENERATOR_URL=http://localhost:8080
